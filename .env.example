DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/grounded_document_assistant
REDIS_URL=redis://localhost:6379
APP_ENV=development
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
FILE_STORAGE_PATH=./storage
INGESTION_CHUNK_SIZE_WORDS=180
INGESTION_CHUNK_OVERLAP_WORDS=30
INGESTION_QUEUE_NAME=grounded-document-assistant-ingestion
INGESTION_JOB_TIMEOUT_SECONDS=600
INGESTION_QUEUE_EAGER=false
LLM_PROVIDER=local
LLM_API_KEY=
LLM_BASE_URL=
CHAT_MODEL=local-grounded-answerer
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash-1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
MAX_UPLOAD_MB=25
